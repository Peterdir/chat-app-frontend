<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Chatappfrontend">

        <!-- Splash / intro screen – declared as LAUNCHER so it is the entry point -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Splash"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Onboarding screen – shown after splash animation completes -->
        <activity
            android:name=".ui.OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Splash" />

        <!-- Register screen -->
        <activity
            android:name=".ui.RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />

        <!-- Login screen -->
        <activity
            android:name=".ui.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />

        <!-- Forgot Password flow -->
        <activity
            android:name=".ui.ForgotPasswordActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />
        <activity
            android:name=".ui.OtpVerificationActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />
        <activity
            android:name=".ui.NewPasswordActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />
        <activity
            android:name=".ui.PasswordChangedActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Chatappfrontend" />

        <!-- Main app screen – started programmatically from OnboardingActivity -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".ui.EditProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Chatappfrontend" />

        <!-- Server channel chat screen -->
        <activity
            android:name=".ui.ServerChatActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />

        <!-- DM private chat screen -->
        <activity
            android:name=".ui.DMChatActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />
    </application>

</manifest>