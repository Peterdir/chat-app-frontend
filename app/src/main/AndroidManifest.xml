<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Chatappfrontend">

        <activity
            android:name=".ui.ServerSettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.SplashActivity"
            android:exported="false"
            android:theme="@style/Theme.Splash"
            android:screenOrientation="portrait">
        </activity>

        <activity
            android:name=".ui.OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Splash" />

        <activity
            android:name=".ui.RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />

        <activity
            android:name=".ui.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />

        <activity
            android:name=".ui.ForgotPasswordActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />
        <activity
            android:name=".ui.OtpVerificationActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />
        <activity
            android:name=".ui.NewPasswordActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />
        <activity
            android:name=".ui.PasswordChangedActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Chatappfrontend" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="false" />

        <activity
            android:name=".ui.EditProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Chatappfrontend" />

        <activity
            android:name=".ui.ShopActivity"
            android:exported="false"
            android:theme="@style/Theme.Chatappfrontend" />

        <activity
            android:name=".ui.ServerChatActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />

        <activity
            android:name=".ui.DMChatActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />

        <activity
            android:name=".ui.VoiceSettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Chatappfrontend" />

        <activity
            android:name=".ui.PrivateCallActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Chatappfrontend">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>

