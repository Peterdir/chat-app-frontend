<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Kết nối mạng tới Server của Agora -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Thu âm giọng nói -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Bật Camera -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <!-- Cho phép thay đổi âm lượng hệ thống, bật/tắt loa ngoài - microphone,... -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <!-- Cho biết đang dùng Wifi hay 4G để tối ưu chất lượng âm thanh -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Để hỗ trợ nghe gọi qua tai nghe Bluetooth -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"/>
    <!-- Hiển thị notification trên Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Chatappfrontend">

        <activity
            android:name=".ui.ServerSettingsActivity"
            android:exported="false" />

        <!-- Splash / intro screen – declared as LAUNCHER so it is the entry point -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Splash"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Onboarding screen – shown after splash animation completes -->
        <activity
            android:name=".ui.OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Splash" />

        <!-- Register screen -->
        <activity
            android:name=".ui.RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />

        <!-- Login screen -->
        <activity
            android:name=".ui.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />

        <!-- Forgot Password flow -->
        <activity
            android:name=".ui.ForgotPasswordActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />
        <activity
            android:name=".ui.OtpVerificationActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />
        <activity
            android:name=".ui.NewPasswordActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />
        <activity
            android:name=".ui.PasswordChangedActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Chatappfrontend" />

        <!-- Main app screen – SỬA Ở ĐÂY: Thêm .ui. vào trước tên class -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="false" />

        <activity
            android:name=".ui.AccountSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Chatappfrontend" />

        <activity
            android:name=".ui.NotificationSettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Chatappfrontend" />

        <activity
            android:name=".ui.EditUsernameActivity"
            android:exported="false"
            android:theme="@style/Theme.Chatappfrontend" />

        <activity
            android:name=".ui.EditProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Chatappfrontend" />

        <activity
            android:name=".ui.ChangePasswordActivity"
            android:exported="false"
            android:theme="@style/Theme.Chatappfrontend" />

        <activity
            android:name=".ui.AppearanceSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Chatappfrontend" />

        <activity
            android:name=".ui.VoiceChannelActivity"
            android:exported="false"
            android:supportsPictureInPicture="true"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
            android:theme="@style/Theme.Chatappfrontend" />
        <activity
            android:name=".ui.ChannelSettingsActivity"
            android:exported="false"/>

        <activity
            android:name=".ui.ShopActivity"
            android:exported="false"
            android:theme="@style/Theme.Chatappfrontend" />

        <!-- Server channel chat screen -->
        <activity
            android:name=".ui.ServerChatActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />

        <activity
            android:name=".ui.NitroActivity"
            android:exported="false"
            android:theme="@style/Theme.Chatappfrontend" />

        <!-- DM private chat screen -->
        <activity
            android:name=".ui.DMChatActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />

        <activity
            android:name=".ui.ServerProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Chatappfrontend" />

        <!-- Friend system screens -->
        <activity
            android:name=".ui.AddFriendActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Chatappfrontend" />

        <activity
            android:name=".ui.FriendListActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Chatappfrontend" />

        <!-- BroadcastReceiver xử lý action Chấp nhận / Từ chối từ notification lời mời kết bạn -->
        <receiver
            android:name=".receiver.FriendRequestReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.chat_app_frontend.ACCEPT_FRIEND" />
                <action android:name="com.example.chat_app_frontend.DECLINE_FRIEND" />
            </intent-filter>
        </receiver>
    </application>

</manifest>