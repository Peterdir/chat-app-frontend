<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Deep dark base -->
    <item>
        <color android:color="#0D0F12" />
    </item>

    <!-- Subtle purple-tinted radial glow at center for depth -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="50%p"
                android:startColor="#0C7C5CF5"
                android:endColor="#00000000"
                android:centerX="0.5"
                android:centerY="0.5" />
        </shape>
    </item>

</layer-list>
