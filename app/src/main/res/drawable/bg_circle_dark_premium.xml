<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#22FFFFFF">
    <item>
        <layer-list>
            <!-- Main Background -->
            <item>
                <shape android:shape="oval">
                    <solid android:color="#2B2D31" />
                </shape>
            </item>
            <!-- Glossy Overlay -->
            <item android:top="2dp" android:left="4dp" android:right="4dp" android:bottom="20dp">
                <shape android:shape="oval">
                    <gradient 
                        android:startColor="#1AFFFFFF" 
                        android:endColor="#00FFFFFF" 
                        android:angle="270" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
