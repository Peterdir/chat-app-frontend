<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Normal State (Default Text or Voice Channel) -->
    <LinearLayout
        android:id="@+id/ll_normal_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_channel_selector"
        android:clickable="true"
        android:focusable="true"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="#"
            android:textColor="@color/discord_text_secondary"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/tv_channel_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="general"
            android:textColor="@color/discord_text_secondary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Connected State (Only shown when this channel is active) -->
    <LinearLayout
        android:id="@+id/ll_connected_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:background="@drawable/bg_channel_selector"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Green Speaker Icon instead of `#` or default emoji -->
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_speaker"
                app:tint="#23A559" />

            <!-- Green Channel Name -->
            <TextView
                android:id="@+id/tv_connected_channel_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="general"
                android:textColor="#23A559"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Live Timer -->
            <Chronometer
                android:id="@+id/timer_connected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#23A559"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- User Row under the connected channel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginStart="24dp">
            
            <FrameLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_marginEnd="8dp">
                
                <ImageView
                    android:id="@+id/iv_connected_user_avatar"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_discord_logo"
                    android:background="@drawable/bg_circle_dark"
                    android:backgroundTint="#5865F2"
                    android:padding="4dp" />
                    
                <!-- Viền xanh khi đang nói (Speaking border) -->
                <!-- 28dp x 28dp allows the 24dp avatar to sit perfectly inside -->
                <View
                    android:id="@+id/v_speaking_border"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:elevation="2dp"
                    android:background="@drawable/bg_circle_green_border"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_connected_user_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Duy"
                android:textColor="#A0A0A0"
                android:textSize="15sp" />

            <ImageView
                android:id="@+id/iv_connected_mute"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_mic_off"
                app:tint="#A0A0A0" />

            <ImageView
                android:id="@+id/iv_connected_video"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_videocam"
                app:tint="#A0A0A0"
                android:visibility="gone" />

            <!-- Activity Icon (Game Controller) shown if status indicates game -->
            <ImageView
                android:id="@+id/iv_connected_activity"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_controller"
                app:tint="#5865F2"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
