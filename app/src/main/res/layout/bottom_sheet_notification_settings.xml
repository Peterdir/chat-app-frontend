<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Handle drag indicator -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_bottom_sheet_handle" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:text="Các Thông Báo"
        android:textColor="@color/discord_text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Group 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_rounded_card"
        android:orientation="vertical">

        <!-- Item 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_at"
                app:tint="@color/discord_text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Hiện các đề cập vai trò"
                android:textColor="@color/discord_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.SwitchCompat
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:checked="true"
                app:switchMinWidth="60dp"
                android:switchPadding="0dp"
                android:splitTrack="false"
                android:thumb="@drawable/selector_discord_switch_thumb"
                android:track="@drawable/selector_discord_switch_track"
                app:trackTint="@color/selector_switch_track_tint"
                app:thumbTint="@null" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#313338" />

        <!-- Item 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_notifications"
                app:tint="@color/discord_text_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hiện các đề cập gián tiếp"
                    android:textColor="@color/discord_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\@here và \@everyone"
                    android:textColor="@color/discord_text_secondary"
                    android:textSize="12sp" />

            </LinearLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_indirect_mentions"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:checked="true"
                app:switchMinWidth="60dp"
                android:switchPadding="0dp"
                android:splitTrack="false"
                android:thumb="@drawable/selector_discord_switch_thumb"
                android:track="@drawable/selector_discord_switch_track"
                app:trackTint="@color/selector_switch_track_tint"
                app:thumbTint="@null" />

        </LinearLayout>

    </LinearLayout>

    <!-- Group 2 -->
    <LinearLayout
        android:id="@+id/btn_notification_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_rounded_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_settings"
            app:tint="@color/discord_text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="Cài đặt thông báo"
            android:textColor="@color/discord_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/discord_text_primary" />

    </LinearLayout>

</LinearLayout>
