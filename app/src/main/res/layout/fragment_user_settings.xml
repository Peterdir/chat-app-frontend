<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/discord_bg_dark">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/discord_bg_dark"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/discord_bg_dark"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@android:color/white"
            app:title="Cài đặt"
            app:titleCentered="true"
            app:titleTextColor="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Search Bar -->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_search_input"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="12dp"
                android:hint="Tìm kiếm"
                android:importantForAutofill="no"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textColor="@android:color/white"
                android:textColorHint="@color/discord_text_secondary"
                android:textSize="14sp" />

            <!-- Account Settings -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="Cài đặt tài khoản"
                android:textAllCaps="true"
                android:textColor="@color/discord_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAccountSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_card"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_settings_row"
                tools:itemCount="8" />

            <!-- Billing Settings -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="Cài đặt thanh toán"
                android:textAllCaps="true"
                android:textColor="@color/discord_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBillingSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_card"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_settings_row"
                tools:itemCount="4" />

            <!-- App Settings -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="Cài đặt ứng dụng"
                android:textAllCaps="true"
                android:textColor="@color/discord_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAppSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_card"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_settings_row"
                tools:itemCount="9" />

            <!-- Support -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="Hỗ trợ"
                android:textAllCaps="true"
                android:textColor="@color/discord_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSupportSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_card"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_settings_row"
                tools:itemCount="3" />

            <!-- What's New -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="Có gì mới"
                android:textAllCaps="true"
                android:textColor="@color/discord_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvWhatsNewSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_card"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_settings_row"
                tools:itemCount="1" />

            <!-- Log Out -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLogoutSetting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_rounded_card"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_settings_row"
                tools:itemCount="1" />

            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
