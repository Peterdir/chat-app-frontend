<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/global_voice_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginBottom="8dp"
    android:visibility="gone"
    app:cardBackgroundColor="#1E1F22"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">

        <!-- Voice Info -->
        <LinearLayout
            android:id="@+id/ll_voice_bar_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_community"
                    app:tint="#23A559" />

                <TextView
                    android:id="@+id/tv_voice_bar_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Đã kết nối Voice"
                    android:textColor="#23A559"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/tv_voice_bar_channel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voice / General"
                    android:textColor="#B5BAC1"
                    android:textSize="12sp"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:maxWidth="150dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="#B5BAC1"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_voice_bar_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#B5BAC1"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Actions -->
        <ImageView
            android:id="@+id/btn_voice_bar_mic"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:padding="8dp"
            android:src="@drawable/ic_mic_on"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#DBDEE1" />

        <ImageView
            android:id="@+id/btn_voice_bar_disconnect"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:src="@drawable/ic_call_end"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#FA777C" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
