<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1F22"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tham gia một máy chủ có sẵn"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Nhập lời mời bên dưới để tham gia một máy chủ có sẵn."
                android:textColor="#B5BAC1"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="8dp"
                android:text="Liên kết mời"
                android:textColor="#B5BAC1"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_invite_link"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_edittext_server"
                android:hint="https://discord.gg/hTKzmak"
                android:textColorHint="#4E5058"
                android:paddingHorizontal="16dp"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_link_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Lời mời trông giống https://discord.gg/hTKzmak, hTKzmak hoặc https://discord.gg/wumpus-friends"
                android:textColor="#B5BAC1"
                android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/btn_join_by_link"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="#5865F2"
            android:text="Tham gia bằng Liên Kết Mời"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="16dp"
            android:gravity="center"
            android:text="HOẶC"
            android:textColor="#80848E"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_join_student_hub"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="#2B2D31"
            android:text="Tham gia một Student Hub"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="24dp" />
    </LinearLayout>

</LinearLayout>