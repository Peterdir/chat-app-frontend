<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0F12"
    android:fitsSystemWindows="true"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingBottom="40dp">

    <!-- Back button -->
    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="52dp"
        android:background="@drawable/bg_back_button"
        android:src="@drawable/ic_chevron_left"
        android:scaleType="center"
        android:contentDescription="@string/otp_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/otp_title"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:lineSpacingMultiplier="1.15"
        app:layout_constraintTop_toBottomOf="@id/btn_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/otp_subtitle"
        android:textColor="#B5BAC1"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.5"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- OTP boxes row -->
    <LinearLayout
        android:id="@+id/otp_row"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/et_otp1"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_otp_box_empty"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:inputType="number"
            android:maxLength="1"
            android:imeOptions="actionNext" />

        <EditText
            android:id="@+id/et_otp2"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_otp_box_empty"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:inputType="number"
            android:maxLength="1"
            android:imeOptions="actionNext" />

        <EditText
            android:id="@+id/et_otp3"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_otp_box_empty"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:inputType="number"
            android:maxLength="1"
            android:imeOptions="actionNext" />

        <EditText
            android:id="@+id/et_otp4"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_otp_box_empty"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:inputType="number"
            android:maxLength="1"
            android:imeOptions="actionDone" />

    </LinearLayout>

    <!-- Verify button -->
    <Button
        android:id="@+id/btn_verify"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginTop="36dp"
        android:background="@drawable/bg_button_blurple"
        android:text="@string/otp_btn_verify"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:letterSpacing="0.04"
        android:stateListAnimator="@null"
        app:layout_constraintTop_toBottomOf="@id/otp_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom: "Didn't received code? Resend" -->
    <TextView
        android:id="@+id/tv_resend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/otp_resend_link"
        android:textColor="#B5BAC1"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
