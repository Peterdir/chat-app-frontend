<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/control_sheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_dark"
    app:behavior_peekHeight="80dp"
    app:behavior_hideable="false"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- Drag Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_marginTop="8dp"
            android:layout_gravity="center_horizontal"
            android:background="#313338" />

        <!-- Top Action Bar (Peek Area) -->
        <LinearLayout
            android:id="@+id/ll_action_bar_peek"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:weightSum="5">

            <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <ImageButton
                    android:id="@+id/btn_video_sheet"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_circle_dark"
                    android:src="@drawable/ic_cam_off"
                    app:tint="#FFFFFF" />
            </FrameLayout>

            <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <ImageButton
                    android:id="@+id/btn_mute_sheet"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_circle_dark"
                    android:src="@drawable/ic_mic_on"
                    app:tint="#FFFFFF" />
            </FrameLayout>

            <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <ImageButton
                    android:id="@+id/btn_chat_sheet"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_circle_dark"
                    android:src="@drawable/ic_chat_bubble"
                    app:tint="#FFFFFF" />
            </FrameLayout>

            <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <ImageButton
                    android:id="@+id/btn_soundboard_sheet"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_circle_dark"
                    android:src="@drawable/ic_community"
                    app:tint="#FFFFFF" />
            </FrameLayout>

            <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
                <ImageButton
                    android:id="@+id/btn_leave_sheet"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_circle_red"
                    android:src="@drawable/ic_call_end"
                    app:tint="#FFFFFF" />
            </FrameLayout>
        </LinearLayout>

        <!-- Main Settings Area (Reveal Area) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="8dp">

            <!-- Card: Activities, Screen Share, Voice Audio -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_card"
                android:backgroundTint="#232428"
                android:orientation="vertical"
                android:padding="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_community"
                        app:tint="#FFFFFF" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Hoạt động"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2b2d31" android:layout_marginStart="52dp" />

                <LinearLayout
                    android:id="@+id/btn_screen_share_sheet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_videocam"
                        app:tint="#FFFFFF" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Chia Sẻ Màn Hình"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2b2d31" android:layout_marginStart="52dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_smiley_dark"
                        app:tint="#FFFFFF" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Đặt Hoạt Động Âm Thanh Voice"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Section: Cài Đặt Giọng Nói -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cài Đặt Giọng Nói"
                android:textColor="#A0A0A0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_card"
                android:backgroundTint="#232428"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- Tắt tiếng -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_speaker_off"
                        app:tint="#FFFFFF" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tắt tiếng"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tắt tất cả âm thanh"
                            android:textColor="#A0A0A0"
                            android:textSize="11sp" />
                    </LinearLayout>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_mute_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumb="@drawable/selector_discord_switch_thumb"
                        android:track="@drawable/selector_discord_switch_track"
                        app:trackTint="@color/selector_switch_track_tint"
                        android:checked="false" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2b2d31" android:layout_marginStart="52dp" />

                <!-- Đổi Đầu Ra Âm Thanh -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_speaker"
                        app:tint="#FFFFFF" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="Đổi Đầu Ra Âm Thanh"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#A0A0A0" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2b2d31" android:layout_marginStart="52dp" />

                <!-- Chỉ hiển thị video -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_camera"
                        app:tint="#FFFFFF" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chỉ hiển thị video"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chúng tôi sẽ không hiển thị thành viên không có video"
                            android:textColor="#A0A0A0"
                            android:textSize="11sp" />
                    </LinearLayout>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_video_only"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumb="@drawable/selector_discord_switch_thumb"
                        android:track="@drawable/selector_discord_switch_track"
                        app:trackTint="@color/selector_switch_track_tint"
                        android:checked="false" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2b2d31" android:layout_marginStart="52dp" />

                <!-- Hiển Thị Camera Của Bản Thân Tôi -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Hiển Thị Camera Của Bản Thân Tôi"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_my_camera"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumb="@drawable/selector_discord_switch_thumb"
                        android:track="@drawable/selector_discord_switch_track"
                        app:trackTint="@color/selector_switch_track_tint"
                        android:checked="true" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2b2d31" />

                <!-- Mời bạn bè -->
                <LinearLayout
                    android:id="@+id/btn_invite_sheet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_person_add"
                        app:tint="#5865F2"
                        android:background="@drawable/bg_circle_dark"
                        android:padding="4dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="Mời bạn bè"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#A0A0A0" />
                </LinearLayout>
            </LinearLayout>

            <!-- Section: Chặn Tiếng Ồn -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chặn Tiếng Ồn"
                android:textColor="#A0A0A0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_card"
                android:backgroundTint="#232428"
                android:padding="8dp">

                <RadioButton
                    android:id="@+id/rb_krisp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Krisp"
                    android:textColor="#FFFFFF"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_discord_radio"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="4dp"
                    android:checked="true" />

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2b2d31" />

                <RadioButton
                    android:id="@+id/rb_standard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tiêu chuẩn"
                    android:textColor="#FFFFFF"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_discord_radio"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="4dp" />

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#2b2d31" />

                <RadioButton
                    android:id="@+id/rb_none"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Không"
                    android:textColor="#FFFFFF"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_discord_radio"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="4dp" />
            </RadioGroup>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chặn các tiếng ồn xung quanh khỏi mic của bạn."
                android:textColor="#A0A0A0"
                android:textSize="11sp"
                android:layout_marginTop="8dp"
                android:layout_marginStart="8dp" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
