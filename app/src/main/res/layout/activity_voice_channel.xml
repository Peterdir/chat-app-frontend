<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000" > <ImageButton
        android:id="@+id/btn_collapse"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:rotation="90"
        android:src="@drawable/ic_chevron_right"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <LinearLayout
        android:id="@+id/pill_channel_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@id/btn_collapse"
        app:layout_constraintEnd_toStartOf="@id/btn_speaker_top"
        app:layout_constraintStart_toEndOf="@id/btn_collapse"
        app:layout_constraintTop_toTopOf="@id/btn_collapse">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/ic_speaker"
                app:tint="#A0A0A0" />
            <TextView
                android:id="@+id/tv_top_channel_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên Kênh"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_participant_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 người trong phòng"
            android:textColor="#A0A0A0"
            android:textSize="12sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_speaker_top"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_circle_white"
        android:src="@drawable/ic_speaker"
        app:layout_constraintBottom_toBottomOf="@id/btn_collapse"
        app:layout_constraintEnd_toStartOf="@id/btn_add_user_top"
        app:layout_constraintTop_toTopOf="@id/btn_collapse"
        app:tint="#000000" />

    <ImageButton
        android:id="@+id/btn_add_user_top"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_person_add"
        app:layout_constraintBottom_toBottomOf="@id/btn_collapse"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btn_collapse"
        app:tint="#FFFFFF" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_center_stage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/banner_add_people"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_collapse">

        <GridLayout
            android:id="@+id/gl_video_grid"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:columnCount="2"
            android:paddingHorizontal="8dp"
            android:rowCount="2"
            android:useDefaultMargins="true"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <FrameLayout
            android:id="@+id/fl_center_avatar_container"
            android:layout_width="140dp"
            android:layout_height="140dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/v_main_speaking_border"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_avatar_speaking_ring"
                android:visibility="gone" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_center_avatar"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                app:cardBackgroundColor="#2B2D31"
                app:cardCornerRadius="60dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/iv_center_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/avatar1" />
            </androidx.cardview.widget.CardView>
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_pill_dark_transparent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/iv_user_mic_status"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_mic_off"
                app:tint="#ED4245" />

            <TextView
                android:id="@+id/tv_user_name_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="You"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/cv_local_preview"
            android:layout_width="100dp"
            android:layout_height="150dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="#2B2D31"
            app:cardCornerRadius="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            
            <FrameLayout
                android:id="@+id/fl_local_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/banner_add_people"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_pill_dark_transparent"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/bottom_action_bar">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_person_add"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Mời thêm người"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottom_action_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_call_bottom_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:weightSum="6"
        app:layout_constraintBottom_toBottomOf="parent">

        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <ImageButton
                android:id="@+id/btn_video"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_dark"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="#FFFFFF" />
        </FrameLayout>

        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <ImageButton
                android:id="@+id/btn_switch_camera"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_dark"
                android:src="@android:drawable/ic_menu_rotate"
                app:tint="#FFFFFF" />
        </FrameLayout>

        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <ImageButton
                android:id="@+id/btn_mute_main"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_white"
                android:src="@drawable/ic_mic_off"
                app:tint="#ED4245" />
        </FrameLayout>

        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <ImageButton
                android:id="@+id/btn_chat_main"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_dark"
                android:src="@drawable/ic_chat_bubble"
                app:tint="#FFFFFF" />
        </FrameLayout>

        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <ImageButton
                android:id="@+id/btn_event_main"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_dark"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                app:tint="#FFFFFF" />
        </FrameLayout>

        <FrameLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1">
            <ImageButton
                android:id="@+id/btn_leave_main"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_red"
                android:src="@drawable/ic_call_end"
                app:tint="#FFFFFF" />
        </FrameLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>