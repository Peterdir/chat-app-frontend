<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageButton
            android:id="@+id/btn_collapse"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:rotation="90"
            android:src="@drawable/ic_chevron_right"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#FFFFFF" />

        <LinearLayout
            android:id="@+id/pill_channel_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/btn_collapse"
            app:layout_constraintEnd_toStartOf="@id/btn_speaker_top"
            app:layout_constraintStart_toEndOf="@id/btn_collapse"
            app:layout_constraintTop_toTopOf="@id/btn_collapse">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="4dp"
                    android:src="@drawable/ic_speaker"
                    app:tint="#A0A0A0" />
                <TextView
                    android:id="@+id/tv_top_channel_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tên Kênh"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_participant_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 người trong phòng"
                android:textColor="#A0A0A0"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_speaker_top"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_circle_white"
            android:src="@drawable/ic_speaker"
            app:layout_constraintBottom_toBottomOf="@id/btn_collapse"
            app:layout_constraintEnd_toStartOf="@id/btn_add_user_top"
            app:layout_constraintTop_toTopOf="@id/btn_collapse"
            app:tint="#000000" />

        <ImageButton
            android:id="@+id/btn_switch_camera_top"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_switch_camera"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/btn_collapse"
            app:layout_constraintEnd_toStartOf="@id/btn_add_user_top"
            app:layout_constraintTop_toTopOf="@id/btn_collapse"
            app:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_add_user_top"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_person_add"
            app:layout_constraintBottom_toBottomOf="@id/btn_collapse"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/btn_collapse"
            app:tint="#FFFFFF" />

        <LinearLayout
            android:id="@+id/cl_center_stage_wrapper"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toTopOf="@+id/banner_add_people"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_collapse">

            <!-- Screen Share Status Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_screen_share_status"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_margin="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#000000"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <FrameLayout
                    android:id="@+id/fl_screen_share_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#111214" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/iv_screen_share_illustration"
                        android:layout_width="160dp"
                        android:layout_height="100dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/bg_circle_dark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Bạn đang chia sẻ màn hình!"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="Bạn có thể đổi sang các ứng dụng khác để bạn bè của bạn xem."
                        android:textColor="#A0A0A0"
                        android:textSize="12sp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_stop_screen_share_main"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_pill_white"
                        android:paddingHorizontal="24dp"
                        android:text="Ngừng chia sẻ"
                        android:textAllCaps="false"
                        android:textColor="#000000"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_videocam"
                        app:tint="#FFFFFF" />
                    <TextView
                        android:id="@+id/tv_share_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="mfun"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Video Grid Area -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <GridLayout
                    android:id="@+id/gl_video_grid"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:columnCount="2"
                    android:paddingHorizontal="8dp"
                    android:rowCount="2"
                    android:useDefaultMargins="true"
                    android:visibility="gone" />

                <!-- Single Avatar Container (Default) -->
                <FrameLayout
                    android:id="@+id/fl_center_avatar_container"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="center">

                    <View
                        android:id="@+id/v_main_speaking_border"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_avatar_speaking_ring"
                        android:visibility="gone" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center"
                        app:cardBackgroundColor="#2B2D31"
                        app:cardCornerRadius="60dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/iv_center_avatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/avatar1" />
                    </androidx.cardview.widget.CardView>
                </FrameLayout>
            </FrameLayout>
        </LinearLayout>

            <!-- Bottom Status Pill -->
            <LinearLayout
                android:id="@+id/status_pill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_pill_dark_transparent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <ImageView
                    android:id="@+id/iv_user_mic_status"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_mic_off"
                    app:tint="#ED4245" />

                <TextView
                    android:id="@+id/tv_user_name_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="You"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_local_preview"
                android:layout_width="100dp"
                android:layout_height="150dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="#2B2D31"
                app:cardCornerRadius="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <FrameLayout
                    android:id="@+id/fl_local_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </androidx.cardview.widget.CardView>



        <LinearLayout
            android:id="@+id/banner_add_people"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="100dp"
            android:background="@drawable/bg_pill_dark_transparent"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_person_add"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Mời thêm người"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Pullable Control Sheet -->
    <include layout="@layout/layout_voice_channel_control_sheet" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
