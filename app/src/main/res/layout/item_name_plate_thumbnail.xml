<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp">

    <RelativeLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_item_selection_outline">

        <ImageView
            android:id="@+id/img_plate"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/img_discord" />

        <!-- Overlay for regular items -->
        <View
            android:id="@+id/overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#80000000"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/placeholder_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">
            <ImageView
                android:id="@+id/img_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_clear"
                app:tint="@color/discord_text_secondary" />
            <TextView
                android:id="@+id/txt_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Không"
                android:textColor="@color/discord_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Lock Icon -->
        <ImageView
            android:id="@+id/img_lock"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="4dp"
            android:src="@drawable/ic_lock"
            android:visibility="gone"
            app:tint="@android:color/white" />

        <!-- Selection border -->
        <View
            android:id="@+id/view_selection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_item_selected_border"
            android:visibility="gone" />

    </RelativeLayout>

    <!-- New Badge -->
    <TextView
        android:id="@+id/txt_new_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="-4dp"
        android:layout_marginEnd="-4dp"
        android:background="@drawable/bg_badge_new"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:text="MỚI"
        android:textColor="@android:color/white"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone" />

</FrameLayout>
