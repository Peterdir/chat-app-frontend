<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/discord_sidebar_bg"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#"
            android:textColor="@color/discord_text_secondary"
            android:textSize="18sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tạo kênh"
            android:textColor="@color/discord_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Channel Type Selection -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LOẠI KÊNH"
        android:textColor="@color/discord_text_secondary"
        android:textSize="12sp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rg_channel_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:id="@+id/layout_text_option"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_edit_input"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <RadioButton
                android:id="@+id/rb_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/discord_text_primary"
                android:buttonTint="@color/discord_blurple" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kênh văn bản"
                    android:textColor="@color/discord_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gửi tin nhắn, hình, GIF, emoji và nhiều hơn nữa"
                    android:textColor="@color/discord_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_voice_option"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_edit_input"
            android:padding="12dp">

            <RadioButton
                android:id="@+id/rb_voice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/discord_text_primary"
                android:buttonTint="@color/discord_blurple" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kênh thoại"
                    android:textColor="@color/discord_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trò chuyện bằng giọng nói và video"
                    android:textColor="@color/discord_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </RadioGroup>

    <!-- Channel Name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TÊN KÊNH *"
        android:textColor="@color/discord_text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/et_channel_name"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@drawable/bg_edit_input"
        android:textColor="@color/discord_text_primary"
        android:textColorHint="@color/discord_text_secondary"
        android:hint="kênh-mới"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="16dp" />

    <!-- Channel Description -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CHỦ ĐỀ KÊNH"
        android:textColor="@color/discord_text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/et_channel_description"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_edit_input"
        android:textColor="@color/discord_text_primary"
        android:textColorHint="@color/discord_text_secondary"
        android:hint="Hãy cho mọi người biết kênh này về chủ đề gì..."
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:gravity="top"
        android:layout_marginBottom="16dp" />

    <!-- Category Selection -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DANH MỤC"
        android:textColor="@color/discord_text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/spinner_category"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@drawable/bg_edit_input"
        android:layout_marginBottom="20dp" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:spacing="8dp">

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Hủy"
            android:textColor="@color/discord_text_primary"
            android:background="@drawable/bg_button_outline"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_create"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Tạo kênh"
            android:textColor="@color/white"
            android:background="@drawable/bg_button_blurple" />
    </LinearLayout>
</LinearLayout>
