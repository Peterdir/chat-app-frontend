<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1e1f22"
    android:orientation="vertical">

    <!-- Top Bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        android:paddingTop="36dp"
        android:paddingBottom="8dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_chevron_right"
            android:rotation="180"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/btn_back"
            android:layout_marginStart="16dp"
            android:text="Cài Đặt Kênh"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:text="Lưu"
            android:textColor="#5865F2"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="8dp" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Tên Kênh -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên kênh"
                android:textColor="#A0A0A0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_channel_name"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_settings_card"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:paddingHorizontal="16dp"
                android:text="z"
                android:singleLine="true" />

            <Space android:layout_width="match_parent" android:layout_height="24dp" />

            <!-- Danh Mục -->
            <LinearLayout
                android:id="@+id/btn_category"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_settings_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_folder" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Danh Mục"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chưa Được Phân Loại"
                    android:textColor="#949BA4"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#949BA4" />
            </LinearLayout>

            <Space android:layout_width="match_parent" android:layout_height="16dp" />

            <!-- Quyền Của Kênh -->
            <LinearLayout
                android:id="@+id/btn_permissions"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_settings_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_shield" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Quyền Của Kênh"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#949BA4" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Thay đổi cài đặt quyền riêng tư và tùy chỉnh cách các thành viên tương tác với kênh này."
                android:textColor="#A0A0A0"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp" />

            <Space android:layout_width="match_parent" android:layout_height="16dp" />

            <!-- Lời Mời -->
            <LinearLayout
                android:id="@+id/btn_invites"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_settings_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_link" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Lời mời"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#949BA4" />
            </LinearLayout>

            <Space android:layout_width="match_parent" android:layout_height="24dp" />

            <!-- Băng Tầng -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="TÚY ÂM! Thiết lập vượt ngưỡng 64kbps có thể ảnh hưởng xấu đến những người có kết nối kém."
                android:textColor="#A0A0A0"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Băng tầng"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tv_bitrate_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="64kbps"
                        android:textColor="#949BA4"
                        android:textSize="14sp" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekbar_bitrate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:progressTint="#5865F2"
                    android:thumbTint="#FFFFFF"
                    android:progressBackgroundTint="#4E5058"
                    android:max="100"
                    android:progress="30" />
            </LinearLayout>

            <Space android:layout_width="match_parent" android:layout_height="24dp" />

            <!-- Chất Lượng Video -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Chất lượng video"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Đặt chất lượng video camera cho tất cả những người tham gia kênh. Chọn Tự động để tối ưu hiệu năng."
                android:textColor="#A0A0A0"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp" />

            <RadioGroup
                android:id="@+id/rg_video_quality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rb_auto"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="16dp"
                    android:text="Tự động"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:buttonTint="#5865F2"
                    android:checked="true"
                    android:layoutDirection="rtl" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1e1f22" />

                <RadioButton
                    android:id="@+id/rb_720p"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingHorizontal="16dp"
                    android:text="720p"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:buttonTint="#949BA4"
                    android:layoutDirection="rtl" />
            </RadioGroup>

            <Space android:layout_width="match_parent" android:layout_height="24dp" />

            <!-- Giới Hạn Người Dùng -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Giới hạn số người dùng có thể kết nối với kênh thoại này. Giới hạn không áp dụng với người dùng có quyền Di Chuyển Thành Viên và có thể chuyển người dùng khác vào kênh."
                android:textColor="#A0A0A0"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giới hạn người dùng"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tv_user_limit_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Không giới hạn"
                        android:textColor="#949BA4"
                        android:textSize="14sp" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekbar_user_limit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:progressTint="#5865F2"
                    android:thumbTint="#FFFFFF"
                    android:progressBackgroundTint="#4E5058"
                    android:max="100"
                    android:progress="0" />
            </LinearLayout>

            <Space android:layout_width="match_parent" android:layout_height="24dp" />

            <!-- Ghi đè khu vực -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Ghi Đè Khu Vực"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Tất cả những người trong kênh này sẽ cố gắng kết nối với khu vực bạn đặt, bất kể họ sống ở đâu. Các khu vực sẽ ảnh hưởng đến chất lượng thoại và video. Đặt ở chế độ Tự Động và Discord sẽ tự tìm ra cách hoạt động tốt nhất."
                android:textColor="#A0A0A0"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp" />

            <LinearLayout
                android:id="@+id/btn_region_override"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_settings_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ghi Đè Khu Vực"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tự động"
                    android:textColor="#949BA4"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#949BA4" />
            </LinearLayout>

            <Space android:layout_width="match_parent" android:layout_height="24dp" />

            <!-- Xóa kênh -->
            <LinearLayout
                android:id="@+id/btn_delete_channel"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_settings_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="32dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_delete" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Xóa kênh"
                    android:textColor="#ED4245"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
