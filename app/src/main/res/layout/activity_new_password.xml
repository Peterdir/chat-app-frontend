<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0F12"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="40dp">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="52dp"
            android:background="@drawable/bg_back_button"
            android:src="@drawable/ic_chevron_left"
            android:scaleType="center"
            android:contentDescription="@string/np_back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/np_title"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.15"
            app:layout_constraintTop_toBottomOf="@id/btn_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/np_subtitle"
            android:textColor="#B5BAC1"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- New Password field -->
        <FrameLayout
            android:id="@+id/container_new_password"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="36dp"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/et_new_password"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_edit_input"
                android:hint="@string/np_hint_new"
                android:textColorHint="#6D6F78"
                android:textColor="#F2F3F5"
                android:textSize="15sp"
                android:paddingStart="18dp"
                android:paddingEnd="56dp"
                android:inputType="textPassword"
                android:imeOptions="actionNext" />

            <CheckBox
                android:id="@+id/cb_eye_new"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="6dp"
                android:button="@drawable/ic_eye_toggle"
                android:background="@null"
                android:contentDescription="@string/login_toggle_password" />

        </FrameLayout>

        <!-- Confirm Password field -->
        <FrameLayout
            android:id="@+id/container_confirm_password"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/container_new_password"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/et_confirm_password"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_edit_input"
                android:hint="@string/np_hint_confirm"
                android:textColorHint="#6D6F78"
                android:textColor="#F2F3F5"
                android:textSize="15sp"
                android:paddingStart="18dp"
                android:paddingEnd="56dp"
                android:inputType="textPassword"
                android:imeOptions="actionDone" />

            <CheckBox
                android:id="@+id/cb_eye_confirm"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="6dp"
                android:button="@drawable/ic_eye_toggle"
                android:background="@null"
                android:contentDescription="@string/login_toggle_password" />

        </FrameLayout>

        <!-- Reset Password button -->
        <Button
            android:id="@+id/btn_reset"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_button_blurple"
            android:text="@string/np_btn_reset"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:stateListAnimator="@null"
            app:layout_constraintTop_toBottomOf="@id/container_confirm_password"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
