<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/discord_bg_dark">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/discord_bg_dark"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/discord_bg_dark"
            app:navigationIcon="@drawable/ic_back_arrow"
            app:navigationIconTint="@android:color/white"
            app:title="Mật khẩu"
            app:titleCentered="true"
            app:titleTextColor="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/discord_bg_dark"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cập nhật mật khẩu của bạn"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center_horizontal"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hãy nhập mật khẩu hiện tại và mật khẩu mới của bạn."
            android:textColor="@color/discord_text_secondary"
            android:textSize="14sp"
            android:gravity="center_horizontal"
            android:layout_marginTop="12dp" />

        <!-- Mật Khẩu Hiện Tại -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mật Khẩu Hiện Tại *"
            android:textColor="@color/discord_text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etCurrentPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edit_input"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:importantForAutofill="no" />

        <!-- Mật Khẩu Mới -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mật Khẩu Mới *"
            android:textColor="@color/discord_text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etNewPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edit_input"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:importantForAutofill="no" />

        <Button
            android:id="@+id/btnChangePassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_button_blurple"
            android:text="Đổi Mật Khẩu"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:alpha="0.5"
            android:enabled="false"
            app:backgroundTint="@null" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>