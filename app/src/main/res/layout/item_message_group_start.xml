<?xml version="1.0" encoding="utf-8"?>
<!-- First message in a group: show avatar + sender name + timestamp + content -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="16dp"
    android:paddingBottom="2dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    <!-- Avatar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_avatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="2dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/discord_blurple">

        <ImageView
            android:id="@+id/img_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/tv_avatar_initial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="U"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </androidx.cardview.widget.CardView>

    <!-- Content column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Name + Timestamp row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <TextView
                android:id="@+id/tv_sender_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username"
                android:textColor="@color/discord_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tv_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today at 09:00"
                android:textColor="@color/discord_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Text content -->
        <TextView
            android:id="@+id/tv_message_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Message content here"
            android:textColor="@color/discord_text_primary"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.2"
            android:visibility="visible" />

        <!-- Image attachment (shown when type=image) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_image_attachment"
            android:layout_width="240dp"
            android:layout_height="160dp"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/discord_card_bg">

            <ImageView
                android:id="@+id/img_attachment"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />
        </androidx.cardview.widget.CardView>

        <!-- Reactions row -->
        <LinearLayout
            android:id="@+id/ll_reactions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_reaction_1"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:background="@drawable/bg_reaction_chip"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textColor="@color/discord_text_primary"
                android:textSize="12sp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tv_reaction_2"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:background="@drawable/bg_reaction_chip"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textColor="@color/discord_text_primary"
                android:textSize="12sp"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
