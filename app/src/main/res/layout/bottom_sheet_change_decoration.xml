<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_bottom_sheet_handle" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đổi Trang Trí Ảnh Đại Diện"
        android:textAlignment="center"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <!-- Main Avatar Preview -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="160dp"
                android:layout_height="160dp">
                <!-- Avatar -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/preview_avatar"
                    android:layout_width="130dp"
                    android:layout_height="130dp"
                    android:layout_gravity="center"
                    android:src="@drawable/img_discord"
                    app:shapeAppearanceOverlay="@style/CircleImage"
                    android:backgroundTint="#FFCC00"/>
                <!-- Decoration -->
                <ImageView
                    android:id="@+id/preview_decoration"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:src="@drawable/frame_aespa_fanlight"
                    android:scaleType="centerInside"/>
            </FrameLayout>

            <!-- Small Previews Grid -->
            <GridLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginStart="24dp">
                
                <FrameLayout android:layout_margin="4dp">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/img_discord"
                        app:shapeAppearanceOverlay="@style/CircleImage"/>
                    <ImageView
                        android:id="@+id/preview_decoration_s1"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:src="@drawable/frame_aespa_fanlight"/>
                </FrameLayout>

                <FrameLayout android:layout_margin="4dp">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/img_discord"
                        app:shapeAppearanceOverlay="@style/CircleImage"/>
                    <ImageView
                        android:id="@+id/preview_decoration_s2"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:src="@drawable/frame_aespa_fanlight"/>
                    <View
                         android:layout_width="12dp"
                         android:layout_height="12dp"
                         android:background="@drawable/bg_status_online"
                         android:layout_gravity="bottom|end"
                         android:layout_margin="2dp"/>
                </FrameLayout>

                <FrameLayout android:layout_margin="4dp">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/img_discord"
                        app:shapeAppearanceOverlay="@style/CircleImage"/>
                    <ImageView
                        android:id="@+id/preview_decoration_s3"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:src="@drawable/frame_aespa_fanlight"/>
                </FrameLayout>

                <FrameLayout android:layout_margin="4dp">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/img_discord"
                        app:shapeAppearanceOverlay="@style/CircleImage"/>
                    <ImageView
                        android:id="@+id/preview_decoration_s4"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:src="@drawable/frame_aespa_fanlight"/>
                    <View
                         android:layout_width="12dp"
                         android:layout_height="12dp"
                         android:background="@drawable/bg_status_online"
                         android:layout_gravity="bottom|end"
                         android:layout_margin="2dp"/>
                </FrameLayout>
            </GridLayout>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/decoration_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tên Trang Trí"
        android:textAlignment="center"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đã nhận vào tháng 1 năm 2026"
        android:textAlignment="center"
        android:textColor="@color/discord_text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="80dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Trang trí của bạn -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trang trí của bạn"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_your_decorations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:layout_marginBottom="16dp" />

                <!-- Dành riêng cho Nitro -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dành riêng cho Nitro"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_nitro_decorations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:layout_marginBottom="16dp" />

                <!-- Ghé xem Cửa hàng -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ghé xem Cửa hàng"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Store item 1 -->
                        <FrameLayout
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_rounded_card"
                            android:layout_marginEnd="8dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@mipmap/ic_launcher"
                                android:padding="8dp"/>
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@android:drawable/ic_lock_lock"
                                android:layout_gravity="top|end"
                                android:layout_margin="4dp"
                                app:tint="@color/discord_text_secondary"/>
                        </FrameLayout>
                        
                        <!-- Store item 2 -->
                        <FrameLayout
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_rounded_card"
                            android:layout_marginEnd="8dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@mipmap/ic_launcher"
                                android:padding="8dp"/>
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@android:drawable/ic_lock_lock"
                                android:layout_gravity="top|end"
                                android:layout_margin="4dp"
                                app:tint="@color/discord_text_secondary"/>
                        </FrameLayout>
                        
                        <!-- Store item 3 -->
                        <FrameLayout
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_rounded_card"
                            android:layout_marginEnd="8dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@mipmap/ic_launcher"
                                android:padding="8dp"/>
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@android:drawable/ic_lock_lock"
                                android:layout_gravity="top|end"
                                android:layout_margin="4dp"
                                app:tint="@color/discord_text_secondary"/>
                        </FrameLayout>

                    </LinearLayout>
                </HorizontalScrollView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_subscribe"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_gravity="bottom"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_nitro_button_gradient"
            android:text="Đăng ký"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
