<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/discord_background"
    android:fitsSystemWindows="true">

    <!-- ========== TOP APP BAR ========== -->
    <LinearLayout
        android:id="@+id/ll_toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/discord_sidebar_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back button -->
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:src="@drawable/ic_chevron_left"
            app:tint="@color/discord_text_secondary" />

        <!-- # icon for text channel -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#"
            android:textColor="@color/discord_text_secondary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginEnd="2dp" />

        <!-- Channel name -->
        <TextView
            android:id="@+id/tv_channel_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="general"
            android:textColor="@color/discord_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginEnd="8dp" />

        <!-- Search -->
        <ImageView
            android:id="@+id/btn_search"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:src="@drawable/ic_search"
            app:tint="@color/discord_text_secondary" />

        <!-- @ Mentions -->
        <ImageView
            android:id="@+id/btn_mentions"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:src="@drawable/ic_notifications"
            app:tint="@color/discord_text_secondary" />

        <!-- Members list -->
        <ImageView
            android:id="@+id/btn_members"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:src="@drawable/ic_members_list"
            app:tint="@color/discord_text_secondary" />

    </LinearLayout>

    <!-- ========== MESSAGES RECYCLER VIEW ========== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/ll_input_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_toolbar" />

    <!-- ========== INPUT BAR ========== -->
    <LinearLayout
        android:id="@+id/ll_input_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/discord_sidebar_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Attach button -->
        <ImageView
            android:id="@+id/btn_attach"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:src="@drawable/ic_attach"
            app:tint="@color/discord_text_secondary" />

        <!-- Text input field -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@drawable/bg_chat_input"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="6dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp">

            <EditText
                android:id="@+id/et_message_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Nhắn #general"
                android:textColorHint="@color/discord_text_secondary"
                android:textColor="@color/discord_text_primary"
                android:textSize="15sp"
                android:maxLines="6"
                android:inputType="textMultiLine|textCapSentences"
                android:imeOptions="flagNoEnterAction" />

            <!-- Emoji button inside input -->
            <ImageView
                android:id="@+id/btn_emoji"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"
                android:src="@drawable/ic_emoji"
                app:tint="@color/discord_text_secondary" />
        </LinearLayout>

        <!-- Send button -->
        <ImageView
            android:id="@+id/btn_send"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_button_blurple"
            android:padding="8dp"
            android:src="@drawable/ic_send" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
