<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0F12"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="40dp">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="52dp"
            android:background="@drawable/bg_back_button"
            android:src="@drawable/ic_chevron_left"
            android:scaleType="center"
            android:contentDescription="@string/login_back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/login_title"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.15"
            app:layout_constraintTop_toBottomOf="@id/btn_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Email field -->
        <EditText
            android:id="@+id/et_email"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="36dp"
            android:background="@drawable/bg_edit_input"
            android:hint="@string/login_hint_email"
            android:textColorHint="#6D6F78"
            android:textColor="#F2F3F5"
            android:textSize="15sp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:inputType="textEmailAddress"
            android:imeOptions="actionNext"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Password field (with eye toggle) -->
        <FrameLayout
            android:id="@+id/password_container"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/et_email"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_edit_input"
                android:hint="@string/login_hint_password"
                android:textColorHint="#6D6F78"
                android:textColor="#F2F3F5"
                android:textSize="15sp"
                android:paddingStart="18dp"
                android:paddingEnd="56dp"
                android:inputType="textPassword"
                android:imeOptions="actionDone" />

            <CheckBox
                android:id="@+id/cb_eye"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="6dp"
                android:button="@drawable/ic_eye_toggle"
                android:background="@null"
                android:contentDescription="@string/login_toggle_password" />

        </FrameLayout>

        <!-- Forgot password link (right-aligned) -->
        <TextView
            android:id="@+id/tv_forgot_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/login_forgot_password"
            android:textColor="#5865F2"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/password_container"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Login button -->
        <Button
            android:id="@+id/btn_login"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_button_blurple"
            android:text="@string/login_btn"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:stateListAnimator="@null"
            app:layout_constraintTop_toBottomOf="@id/tv_forgot_password"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Divider: "Or Login with" -->
        <LinearLayout
            android:id="@+id/divider_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/btn_login"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#2A2C30" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:text="@string/login_or_with"
                android:textColor="#6D6F78"
                android:textSize="13sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#2A2C30" />

        </LinearLayout>

        <!-- Social buttons row -->
        <LinearLayout
            android:id="@+id/social_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/divider_row"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                android:id="@+id/btn_facebook"
                android:layout_width="64dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_social_button"
                android:src="@drawable/ic_facebook"
                android:scaleType="center"
                android:contentDescription="@string/login_via_facebook" />

            <ImageButton
                android:id="@+id/btn_google"
                android:layout_width="64dp"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_social_button"
                android:src="@drawable/ic_google"
                android:scaleType="center"
                android:contentDescription="@string/login_via_google" />

        </LinearLayout>

        <!-- Bottom: "Don't have an account? Register Now" -->
        <TextView
            android:id="@+id/tv_register_link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/login_register_link"
            android:textColor="#B5BAC1"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/social_row"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
